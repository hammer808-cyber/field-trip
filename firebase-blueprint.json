{
  "entities": {
    "User": {
      "title": "User",
      "description": "Core player profile. Identity, points, and progression state.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "username": { "type": "string" },
        "points": { "type": "number", "description": "Global XP total." },
        "soloTripsCount": { "type": "number", "description": "Count of approved solo entries for onboarding." },
        "approvedEntriesCount": { "type": "number" },
        "fieldType": { "type": "string", "description": "Field Agent persona ID (e.g. field type, researcher)." },
        "fieldTypeName": { "type": "string" },
        "fieldClassificationComplete": { "type": "boolean" },
        "productPersonaLens": { "type": "string", "enum": ["frankie", "glitch", "baja", "diamond"] },
        "avatar": { "type": "object", "description": "Serialized Avatar data." },
        "crewId": { "type": "string", "description": "Current crew membership ID." },
        "crewModeUnlocked": { "type": "boolean" },
        "crewModeSeen": { "type": "boolean" },
        "onboardingCompleted": { "type": "boolean" },
        "frankieMode": { "type": "boolean", "description": "Plain language system flag." },
        "plainMode": { "type": "boolean", "description": "Deprecated - use frankieMode." },
        "seenBadges": { "type": "array", "items": { "type": "string" } },
        "maybeList": { "type": "array", "items": { "type": "string" }, "description": "Queued challenge IDs." },
        "previousRank": { "type": "number" },
        "rerollsAvailable": { "type": "number" },
        "tripProgress": { 
          "type": "object", 
          "description": "Per-challenge progress tracking for unsubmitted missions.",
          "additionalProperties": {
             "type": "object",
             "properties": {
               "photo": { "type": "boolean" },
               "field_note": { "type": "boolean" },
               "location": { "type": "boolean" }
             }
          }
        },
        "comebackCardActive": { "type": "boolean" },
        "fieldCheckHistory": { "type": "array", "items": { "type": "string" }, "description": "Timestamps of recent field check requests." },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "points", "createdAt"]
    },
    "Entry": {
      "title": "Entry",
      "description": "A field report submission. Links challenge to proof and user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "crewId": { "type": "string" },
        "tripId": { "type": "string", "description": "ID of the challenge template." },
        "tripTitle": { "type": "string" },
        "fieldNote": { "type": "string" },
        "proofImage": { "type": "string", "description": "Storage URL of the evidence." },
        "imageStoragePath": { "type": "string" },
        "selectedLevel": { "type": "string", "enum": ["Standard", "Advanced", "Certified"] },
        "detourCompleted": { "type": "boolean" },
        "status": { "type": "string", "enum": ["submitted", "approved", "rejected", "needs_fix", "under_field_check"] },
        "pointsAwarded": { "type": "number" },
        "proofCheckId": { "type": "string", "description": "Reference to the AI review record." },
        "adminNotes": { "type": "string" },
        "uploadSource": { "type": "string", "enum": ["camera", "upload"] },
        "photoTakenAt": { "type": "string", "format": "date-time" },
        "fileLastModifiedAt": { "type": "string", "format": "date-time" },
        "metadataStatus": { "type": "string", "enum": ["verified", "missing", "suspicious"] },
        "captureTrustLevel": { "type": "string" },
        "filterUsed": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "tripId", "status", "createdAt"]
    },
    "Challenge": {
      "title": "Challenge",
      "description": "A field mission template.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string" },
        "basePoints": { "type": "number" },
        "levels": {
          "type": "object",
          "properties": {
            "Standard": { "type": "object", "properties": { "points": { "type": "number" }, "description": { "type": "string" }, "rule": { "type": "string" } } },
            "Advanced": { "type": "object", "properties": { "points": { "type": "number" }, "description": { "type": "string" }, "rule": { "type": "string" } } },
            "Certified": { "type": "object", "properties": { "points": { "type": "number" }, "description": { "type": "string" }, "rule": { "type": "string" } } }
          }
        },
        "mode": { "type": "string", "enum": ["solo", "crew", "flexible"] },
        "status": { "type": "string", "enum": ["draft", "approved", "scheduled", "active", "archived", "available"] },
        "requiredProof": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "status"]
    },
    "AppConfig": {
      "title": "AppConfig",
      "description": "Global game settings and feature flags.",
      "type": "object",
      "properties": {
        "activeSeasonId": { "type": "string" },
        "featureFlags": { "type": "object" },
        "onboardingEntriesRequired": { "type": "number" },
        "userSkinSelectionEnabled": { "type": "boolean" }
      }
    },
    "Season": {
      "title": "Season",
      "description": "Temporal game container.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "closed", "pre-season"] },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "weeks": { "type": "array" }
      }
    },
    "FieldCheck": {
      "title": "FieldCheck",
      "description": "User-initiated dispute or audit request.",
      "type": "object",
      "properties": {
        "reporterId": { "type": "string" },
        "targetId": { "type": "string", "description": "Entry ID being checked." },
        "targetUserId": { "type": "string" },
        "reason": { "type": "string" },
        "details": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "cleared", "adjusted", "rejected", "dismissed"] },
        "defense": { "type": "string" },
        "defenseSubmittedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ProofReview": {
      "title": "ProofReview",
      "description": "AI analysis trail for an entry.",
      "type": "object",
      "properties": {
        "entryId": { "type": "string" },
        "status": { "type": "string" },
        "confidenceScore": { "type": "number" },
        "reviewNotes": { "type": "string" },
        "isPurged": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "WeeklySummary": {
      "title": "WeeklySummary",
      "description": "Aggregated leaderboard data per week.",
      "type": "object",
      "properties": {
        "seasonId": { "type": "string" },
        "weekNumber": { "type": "number" },
        "playerStats": { "type": "object" },
        "crewStats": { "type": "object" },
        "lastCalculatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Player profiles."
    },
    "/usernames/{username}": {
      "schema": { "type": "object", "properties": { "userId": { "type": "string" } } },
      "description": "Username uniqueness registry."
    },
    "/entries/{entryId}": {
      "schema": "Entry",
      "description": "Submission reports (the core content collection)."
    },
    "/challenges/{challengeId}": {
      "schema": "Challenge",
      "description": "Available mission templates."
    },
    "/appConfig/{docId}": {
      "schema": "AppConfig",
      "description": "System settings (e.g. /game, /skinSettings)."
    },
    "/seasons/{seasonId}": {
      "schema": "Season",
      "description": "Season configuration."
    },
    "/fieldChecks/{checkId}": {
      "schema": "FieldCheck",
      "description": "Dispute and audit records."
    },
    "/proofReviews/{reviewId}": {
      "schema": "ProofReview",
      "description": "AI auditing trail."
    },
    "/proofChecks/{cacheKey}": {
      "schema": { "type": "object" },
      "description": "Quota and duplicate submission caching."
    },
    "/proofRequirements/{challengeId}": {
      "schema": { "type": "object" },
      "description": "Challenge-specific AI scoring rules."
    },
    "/weeklySummaries/{summaryId}": {
      "schema": "WeeklySummary",
      "description": "Leaderboard snapshots."
    },
    "/scoreEvents/{eventId}": {
      "schema": { "type": "object" },
      "description": "Granular ledger of all point transactions."
    },
    "/crews/{crewId}": {
      "schema": { "type": "object" },
      "description": "Team definitions."
    },
    "/crewLore/{crewId}": {
      "schema": { "type": "object" },
      "description": "Team-specific persistent history."
    },
    "/crewDispatches/{dispatchId}": {
      "schema": { "type": "object" },
      "description": "End-of-season recaps."
    },
    "/crewArtifacts/{artifactId}": {
      "schema": { "type": "object" },
      "description": "Collectible team items."
    },
    "/badgeProgress/{progressId}": {
      "schema": { "type": "object" },
      "description": "User progress toward specific badges."
    },
    "/badgeFragments/{fragmentId}": {
      "schema": { "type": "object" },
      "description": "Individual achievement components."
    },
    "/observations/{obsId}": {
      "schema": { "type": "object" },
      "description": "System-generated insights/logs."
    },
    "/fieldSignals/{signalId}": {
      "schema": { "type": "object" },
      "description": "Global event tracking (Canvas/Signal)."
    },
    "/reports/{reportId}": {
      "schema": { "type": "object" },
      "description": "User reports for moderation."
    },
    "/moderationAudit/{auditId}": {
      "schema": { "type": "object" },
      "description": "Admin action log."
    },
    "/skins/{skinId}": {
      "schema": { "type": "object" },
      "description": "Available visual themes."
    },
    "/userPrefs/{userId}": {
      "schema": { "type": "object" },
      "description": "User-specific theme/UI settings."
    },
    "/votes/{voteId}": {
      "schema": { "type": "object" },
      "description": "Social voting records."
    },
    "/admins/{userId}": {
      "schema": { "type": "object" },
      "description": "RBAC whitelist for admin access."
    },
    "/accessCodes/{code}": {
      "schema": { "type": "object" },
      "description": "Beta invite codes."
    },
    "/activeSabotages/{sabId}": {
      "schema": { "type": "object" },
      "description": "Active in-game interference events."
    }
  }
}
