# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_RECAPTCHA_SITE_KEY: Required for Firebase App Check (v3).
# Register your app in Firebase Console and create a reCAPTCHA v3 site key.
VITE_RECAPTCHA_SITE_KEY=

# VITE_RECAPTCHA_ENTERPRISE_SITE_KEY: Optional alternative for App Check (Enterprise).
# If provided, this will be preferred over v3.
VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=

# Firebase Configuration
FIREBASE_PROJECT_ID=field-trip-495823
FIRESTORE_DATABASE_ID=ai-studio-6bdf91b5-28e9-46f3-ae49-89cf99e2d88a
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
 
# ENFORCE_APP_CHECK: If "true", the Express server will reject requests without a valid App Check token.
# Useful for production hardening.
ENFORCE_APP_CHECK=false

# ENABLE_STARTUP_FIRESTORE_WARMUP: Optional server-side IAM smoke write.
# Leave false/unset in production unless intentionally testing runtime IAM from logs.
ENABLE_STARTUP_FIRESTORE_WARMUP=false

# VITE_FIREBASE_APPCHECK_DEBUG: If "true", forces the Firebase App Check debug provider.
# Use this when testing in AI Studio or other non-production preview environments.
VITE_FIREBASE_APPCHECK_DEBUG=false
