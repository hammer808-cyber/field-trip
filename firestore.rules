rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // 0. PUBLIC CONFIGS (ALLOW READ ALWAYS)
    // =========================================================================
    match /appConfig/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /skins/{skinId} {
      // Skin manifests contain presentation metadata only. Reading every status
      // lets clients honor an admin-disabled built-in instead of restoring its
      // local fallback; selection and writes remain separately enforced.
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
    match /fieldSignals/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /seasons/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // =========================================================================
    // 1. HELPERS & PILLARS
    // =========================================================================

    // Deployment Heartbeat: 2026-06-10T07:37:30Z
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        // Allow developer email (ignore verified status in preview/dev mode)
        (request.auth.token.get('email', '') == 'hammer808@gmail.com') ||
        // Hardcoded UID for the developer
        (request.auth.uid == 'vX7K0XGkXRM2yPzhidv79Q59GqC2') ||
        (request.auth.uid == 'oae0GwP7mpcUX7i93AeDGd22VNu2') ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true))
      );
    }
    function isApproved() {
      return isSignedIn() && (
        isAdmin() ||
        // Allow if user exists and is approved
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('accessStatus', 'pending') == 'approved') ||
        // Always allow if they have a profile during beta (simplified gate)
        exists(/databases/$(database)/documents/users/$(request.auth.uid))
      );
    }
    function isTribunalEligible() {
      return isSignedIn() && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('starterApprovedCount', 0) >= 3)
      );
    }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isValidAccessCode(data) {
      return data.keys().hasAll(['active', 'maxUses', 'currentUses', 'createdAt']) &&
             data.active is bool &&
             data.maxUses is int &&
             data.currentUses is int &&
             data.createdAt is timestamp;
    }
    function canUseAccessCode(codeId) {
      let code = get(/databases/$(database)/documents/accessCodes/$(codeId)).data;
      let usage = code.get('currentUses', 0) > 0 ? code.currentUses : code.get('uses', 0);
      return code.active == true && (code.maxUses == 0 || usage < code.maxUses);
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function requestTime() { return request.time; }
    function currentUserProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function activeCrewId() {
      return currentUserProfile().get('activeCrewId', currentUserProfile().get('crewId', ''));
    }
    function isActiveCrewMemberOf(crewId) {
      return isSignedIn() &&
             crewId is string &&
             crewId.size() > 0 &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             activeCrewId() == crewId &&
             exists(/databases/$(database)/documents/crews/$(crewId)/members/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/crews/$(crewId)/members/$(request.auth.uid)).data.get('status', '') == 'active';
    }
    function isCrewCaptainOf(crewId) {
      return isActiveCrewMemberOf(crewId) &&
             exists(/databases/$(database)/documents/crews/$(crewId)) &&
             get(/databases/$(database)/documents/crews/$(crewId)).data.get(
               'captainId',
               get(/databases/$(database)/documents/crews/$(crewId)).data.get('founderId', '')
             ) == request.auth.uid;
    }
    function canReadCrewArchive(data) {
      return isAdmin() ||
             isActiveCrewMemberOf(data.get('crewId', '')) ||
             (
               data.get('status', '') in ['finalized', 'archived'] &&
               data.get('viewerUserIdsSnapshot', []).hasAny([request.auth.uid])
             );
    }
    function hasDeckInviteRedemption(deckId) {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             currentUserProfile().get('deckInviteRedemptions', {}).get(deckId, null) != null;
    }
    function deckAccessWindowOpen(deck) {
      return (deck.get('accessStartsAt', null) == null || request.time >= deck.accessStartsAt) &&
             (deck.get('accessEndsAt', null) == null || request.time <= deck.accessEndsAt);
    }
    function deckPrerequisitesMet(deck) {
      let profile = currentUserProfile();
      return !deck.keys().hasAny(['requiredCredentialIds']) || deck.requiredCredentialIds.size() == 0 ||
             profile.get('credentialIds', []).hasAll(deck.requiredCredentialIds);
    }
    function canUseDeck(deckId) {
      return isSignedIn() && (
        deckId == null ||
        deckId == '' ||
        !exists(/databases/$(database)/documents/decks/$(deckId)) ||
        isAdmin() ||
        (
          deckAccessWindowOpen(get(/databases/$(database)/documents/decks/$(deckId)).data) &&
          deckPrerequisitesMet(get(/databases/$(database)/documents/decks/$(deckId)).data) &&
          (
            get(/databases/$(database)/documents/decks/$(deckId)).data.get('visibility', 'public') == 'public' ||
            (
              get(/databases/$(database)/documents/decks/$(deckId)).data.visibility == 'assigned_users' &&
              get(/databases/$(database)/documents/decks/$(deckId)).data.get('assignedUserIds', []).hasAny([request.auth.uid])
            ) ||
            (
              get(/databases/$(database)/documents/decks/$(deckId)).data.visibility == 'crew_only' &&
              exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
              get(/databases/$(database)/documents/decks/$(deckId)).data.get('allowedCrewIds', []).hasAny([activeCrewId()])
            ) ||
            (
              get(/databases/$(database)/documents/decks/$(deckId)).data.visibility == 'invite_code' &&
              hasDeckInviteRedemption(deckId)
            )
          )
        )
      );
    }

    // ADMIN COLLECTION-GROUP DIAGNOSTICS
    // Allows Admin Proof Review to scan proof records regardless of whether
    // a legacy path wrote them at the root or under a user-scoped subcollection.
    // Writes still go through the concrete collection rules below.
    match /{path=**}/entries/{entryId} {
      allow get, list: if isAdmin();
    }
    match /{path=**}/proofReviews/{id} {
      allow get, list: if isAdmin();
    }

    // =========================================================================
    // 2. CATCH-ALL DENY (Moved to end for better matching behavior)
    // =========================================================================
    // match /{document=**} { allow read, write: if false; }

    // =========================================================================
    // 3. COLLECTIONS
    // =========================================================================

    // ADMIN ACCESS
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // USERNAMES (Unique Mapping)
    match /usernames/{username} {
      function isValidUsername(data) {
        return data.keys().hasAll(['userId', 'createdAt']) &&
               data.keys().size() == 2 &&
               data.userId == request.auth.uid &&
               data.createdAt == requestTime();
      }
      allow read: if true;
      allow create: if isSignedIn() && isValidUsername(incoming()) && username.size() <= 32;
    }

    // ACCESS CODES (Invite Codes)
    match /accessCodes/{code} {
      // Not publicly readable (list), but getable if you know the code
      allow get: if true; 
      allow list: if false;
      allow update: if isSignedIn() && (
        // Case 1: Pre-auth validation (Increment uses/currentUses and server-side tracking)
        (
          incoming().diff(existing()).affectedKeys().hasOnly(['currentUses', 'usedBy', 'uses', 'lastValidatedAt']) &&
          (existing().maxUses == 0 || (existing().get('currentUses', 0) < existing().maxUses || existing().get('uses', 0) < existing().maxUses))
        ) ||
        // Case 2: Post-auth registration tracking
        (
          incoming().diff(existing()).affectedKeys().hasOnly(['lastRegisteredAt', 'lastRegisteredUser'])
        )
      );
      allow create: if isAdmin() && isValidAccessCode(incoming()) && isValidId(code);
      allow delete: if isAdmin();
    }

    // USERS (Identity & RBAC)
    match /users/{uId} {
      function isSystemProtected(data, existing) {
        let protectedFields = [
          'xp', 'totalXP', 'weeklyXp', 'weeklyXP', 'seasonXp', 'seasonXP',
          'level', 'levelTitle', 'progressionRewardIds', 'progressionUpdatedAt',
          'weeklyRank', 'seasonRank', 'role',
          'submittedPendingChallengeIds', 'submittedChallengeIds', 
          'approvedCompletedChallengeIds', 'approvedEntriesCount',
          'points', 'score', 'totalPoints', 'rank', 'tokens', // legacy but still protected
          'deckInviteRedemptions', 'redeemedDeckInviteIds',
          'credentialIds', 'completedCredentialIds', 'completedDeckIds', 'approvedCompletedDeckIds',
          'activeCrewId', 'crewId', 'crewRole', 'crewCooldownUntil', 'crewJoinedAt',
          'equippedSkinId',
          'comebackCardActive', 'comebackCardGrantedAt', 'comebackCardRedeemedAt'
        ];
        
        // Block if any protected field is being changed
        let isEditingProtected = data.diff(existing).affectedKeys().hasAny(protectedFields);
        let isEditingSkinOwnership =
          data.get('unlockedRewards', {}).get('skins', ['classic']) !=
          existing.get('unlockedRewards', {}).get('skins', ['classic']);
        
        // Special Case: fieldType. We protect it from UPDATES, but allow INITIAL SETTING if currently null.
        // This lets the onboarding quiz work while preventing users from changing it later to farm rewards.
        let isInitialFieldTypeSet = existing.get('fieldType', null) == null && 
                                   data.diff(existing).affectedKeys().hasOnly(['fieldType', 'fieldTypeName', 'fieldClassificationComplete', 'fieldTypeQuizCompleted', 'fieldTypeScores', 'fieldTypeAssignedAt', 'fieldTypeLastUpdatedAt', 'updatedAt', 'avatar']);

        let isFieldTypeUpdate = data.diff(existing).affectedKeys().hasAny(['fieldType', 'fieldTypeName', 'fieldClassificationComplete']);

        return (isEditingProtected || isEditingSkinOwnership || (isFieldTypeUpdate && !isInitialFieldTypeSet));
      }

      function isProgressionProtected(data, existing) {
        return data.diff(existing).affectedKeys().hasAny([
          'xp', 'totalXP', 'weeklyXp', 'weeklyXP', 'seasonXp', 'seasonXP',
          'level', 'levelTitle', 'progressionRewardIds', 'progressionUpdatedAt',
          'weeklyRank', 'seasonRank',
          'points', 'score', 'totalPoints', 'rank',
          'comebackCardActive', 'comebackCardGrantedAt', 'comebackCardRedeemedAt'
        ]);
      }

      function hasSafeInitialSkinState(data) {
        return data.get('equippedSkinId', 'classic') == 'classic' &&
               data.get('unlockedRewards', {}).get('skins', ['classic']).hasOnly(['classic']);
      }

      function hasSafeInitialProgressionState(data) {
        return data.get('xp', 0) == 0 &&
               data.get('totalXP', 0) == 0 &&
               data.get('weeklyXp', 0) == 0 &&
               data.get('weeklyXP', 0) == 0 &&
               data.get('seasonXp', 0) == 0 &&
               data.get('seasonXP', 0) == 0 &&
               data.get('points', 0) == 0 &&
               data.get('level', 1) == 1 &&
               data.get('levelTitle', 'Person of Mild Interest') == 'Person of Mild Interest' &&
               data.get('progressionRewardIds', []).size() == 0 &&
               data.get('weeklyRank', null) == null &&
               data.get('seasonRank', null) == null &&
               data.get('comebackCardActive', false) == false &&
               data.get('isAdmin', false) == false &&
               data.get('role', 'player') in ['player', null];
      }

      // allow get is more robust for non-existent profiles during registration
      allow get: if isSignedIn() && (uId == request.auth.uid || isAdmin());
      allow list: if isSignedIn();
      allow create: if isSignedIn() && hasSafeInitialProgressionState(incoming()) && (
        isAdmin() || (uId == request.auth.uid && hasSafeInitialSkinState(incoming()))
      );
      allow update: if isSignedIn() && (uId == request.auth.uid || isAdmin()) && (
        !isProgressionProtected(incoming(), existing()) &&
        (isAdmin() || !isSystemProtected(incoming(), existing()))
      );
      allow delete: if isAdmin();
      
      // Allow recursive access to own subcollections (blocks, legalConsents, etc.)
      match /blocks/{blockId} {
        allow read, write: if isSignedIn() && (uId == request.auth.uid || isAdmin());
      }
      match /legalConsents/{consentId} {
        allow read, write: if isSignedIn() && (uId == request.auth.uid || isAdmin());
      }
      match /stickers/{stickerId} {
        function isKnownStickerId() {
          return stickerId in [
            'captain_clipboard_clipboard_character',
            'captain_clipboard_checklist_badge',
            'captain_clipboard_checkmark_seal',
            'captain_clipboard_pen_sparkle',
            'captain_clipboard_flying_papers',
            'captain_clipboard_whistle_lanyard',
            'captain_clipboard_field_notes',
            'mall_rat_shopping_bags',
            'mall_rat_receipt_curl',
            'mall_rat_sunglasses',
            'mall_rat_food_court_tray',
            'mall_rat_escalator_pose',
            'mall_rat_soda_cup',
            'mall_rat_mall_map',
            'mascota_mascot_jump',
            'mascota_pom_poms',
            'mascota_foam_finger',
            'mascota_confetti_burst',
            'mascota_megaphone',
            'mascota_mascot_face',
            'mascota_victory_flag',
            'elondra_crown',
            'elondra_compact_mirror',
            'elondra_sparkle_burst',
            'elondra_glam_pose',
            'elondra_glam_shoe',
            'elondra_purse',
            'elondra_arrival_pose',
            'lost_camper_map',
            'lost_camper_flashlight',
            'lost_camper_backpack',
            'lost_camper_compass',
            'lost_camper_bandage',
            'lost_camper_trail_sign',
            'lost_camper_nervous_camper',
            'bigfoot_footprint',
            'bigfoot_tree_hideout',
            'bigfoot_blurry_polaroid',
            'bigfoot_pine_trees',
            'bigfoot_peace_sign',
            'bigfoot_campfire_snack',
            'bigfoot_night_silhouette'
          ];
        }

        function isValidStickerTrigger(trigger) {
          return trigger in [
            'starter_pack',
            'first_submission',
            'first_approval',
            'field_note_added',
            'photo_proof_added',
            'challenge_approved',
            'weekly_vote_cast',
            'weekly_winner',
            'crew_joined',
            'crew_created',
            'zine_page_added',
            'archetype_milestone',
            'season_milestone',
            'admin_grant'
          ];
        }

        function isValidStickerUnlock() {
          let data = incoming();
          return isKnownStickerId() &&
                 data.keys().hasAll(['stickerId', 'unlockedAt', 'source', 'trigger', 'seen', 'equipped']) &&
                 data.keys().hasOnly(['stickerId', 'unlockedAt', 'source', 'trigger', 'seen', 'equipped']) &&
                 data.stickerId == stickerId &&
                 data.unlockedAt == requestTime() &&
                 data.source is string &&
                 data.source.size() > 0 &&
                 data.source.size() <= 200 &&
                 isValidStickerTrigger(data.trigger) &&
                 data.seen == false &&
                 data.equipped == false;
        }

        function isValidStickerPreferenceUpdate() {
          return incoming().diff(existing()).affectedKeys().hasOnly(['seen', 'equipped']) &&
                 incoming().seen is bool &&
                 incoming().equipped is bool &&
                 (
                   incoming().seen == existing().seen ||
                   (existing().seen == false && incoming().seen == true)
                 );
        }

        allow read: if isSignedIn() && (uId == request.auth.uid || isAdmin());
        allow create: if isAdmin() || (
          isSignedIn() &&
          uId == request.auth.uid &&
          isValidStickerUnlock()
        );
        allow update: if isAdmin() || (
          isSignedIn() &&
          uId == request.auth.uid &&
          isValidStickerPreferenceUpdate()
        );
        allow delete: if isAdmin();
      }
      match /drawnMissionCards/{mId} {
        function isValidDrawnCard(data) {
          return data.keys().hasAll(['uid', 'missionId', 'status', 'drawnAt']) &&
                 data.uid == uId &&
                 data.status in ["drawn", "saved_for_later", "active", "pending_review", "needs_more_proof", "approved", "rejected"];
        }
        allow read: if isSignedIn() && (uId == request.auth.uid || isAdmin());
        allow create: if isSignedIn() && uId == request.auth.uid && isValidDrawnCard(incoming());
        allow update: if (isSignedIn() && uId == request.auth.uid && isValidDrawnCard(incoming())) || isAdmin();
        allow delete: if isAdmin();
      }
      match /memories/{memoryId} {
        allow read: if isSignedIn() && (uId == request.auth.uid || isAdmin());
        allow create: if isAdmin();
        allow update: if isSignedIn() && uId == request.auth.uid && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['favorite']);
        allow delete: if isAdmin();
      }

      match /susReports/{id} {
        allow read, write: if false;
      }
      match /susReportCounters/{id} {
        allow read, write: if false;
      }
      match /susAbuseSignals/{id} {
        allow read, write: if false;
      }
      match /tribunalCases/{id} {
        allow read, write: if false;
      }
      match /tribunalCasePrivate/{id} {
        allow read, write: if false;
      }
      match /tribunalVotes/{id} {
        allow read, write: if false;
      }
      match /tribunalVoteAudit/{id} {
        allow read, write: if false;
      }
      match /tribunalResults/{id} {
        allow read, write: if false;
      }
      
      match /{allPaths=**} {
        allow read: if isSignedIn() &&
          (uId == request.auth.uid || isAdmin()) &&
          !allPaths.matches('^(susReports|susReportCounters|susAbuseSignals|tribunalCases|tribunalCasePrivate|tribunalVotes|tribunalVoteAudit|tribunalResults)/.*');
        allow write: if isAdmin() &&
          !allPaths.matches('^(susReports|susReportCounters|susAbuseSignals|tribunalCases|tribunalCasePrivate|tribunalVotes|tribunalVoteAudit|tribunalResults)/.*');
      }
    }

    match /userPrefs/{userId} {
      function isBuiltInSkin(skinId) {
        return skinId in ['classic', 'arcade', 'journal', 'baja-bratz'];
      }
      function isAvailableSkin(skinId) {
        return skinId == 'classic' ||
               (
                 isBuiltInSkin(skinId) &&
                 !exists(/databases/$(database)/documents/skins/$(skinId))
               ) ||
               (
                 exists(/databases/$(database)/documents/skins/$(skinId)) &&
                 get(/databases/$(database)/documents/skins/$(skinId)).data.get('status', 'inactive') == 'active'
               );
      }
      function isGlobalDefaultSkin(skinId) {
        return exists(/databases/$(database)/documents/appConfig/skinSettings) &&
               get(/databases/$(database)/documents/appConfig/skinSettings).data.get('defaultSkinId', 'classic') == skinId;
      }
      function ownsRequestedSkin(skinId) {
        let profile = get(/databases/$(database)/documents/users/$(userId)).data;
        return isAvailableSkin(skinId) && (
          skinId == 'classic' ||
          isGlobalDefaultSkin(skinId) ||
          profile.get('equippedSkinId', '') == skinId ||
          profile.get('unlockedRewards', {}).get('skins', []).hasAny([skinId])
        );
      }
      function isValidThemePreferenceWrite() {
        return incoming().keys().hasOnly(['selectedSkinId', 'frankieMode', 'reduceCommentary', 'updatedAt']) &&
               incoming().get('selectedSkinId', 'classic') is string &&
               ownsRequestedSkin(incoming().get('selectedSkinId', 'classic'));
      }

      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAdmin() || (isOwner(userId) && isValidThemePreferenceWrite());
      allow update: if isAdmin() || (isOwner(userId) && isValidThemePreferenceWrite());
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /badgeProgress/{id} {
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /observations/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && existing().userId == request.auth.uid && (
        incoming().diff(existing()).affectedKeys().hasOnly(['isDismissed'])
      );
      allow delete: if isAdmin();
    }

    match /badgeFragments/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ENTRIES (Submissions)
    match /entries/{entryId} {
      function isValidEntry(data) {
        return data.keys().hasAll(['userId', 'status', 'createdAt']) &&
               data.userId == request.auth.uid &&
               data.status in ['pending', 'submitted', 'available', 'approved', 'rejected', 'needs_more_proof', 'under_field_check', 'needs_review', 'retry-submitted', 'auto_approved', 'pending_upload', 'pending_review'] &&
               (data.fieldNote == null || data.fieldNote.size() <= 1000);
      }

      allow read: if isAdmin() || isApproved() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin() || isApproved();
      
      // Proof submission must be allowed for signed-in users before review.
      // Approval gates review/admin/public systems; it should not block creating
      // the canonical pending_review entry itself.
      allow create: if (isSignedIn() && isValidId(entryId) && isValidEntry(incoming()) &&
                    canUseDeck(incoming().get('deckId', '')) &&
                    incoming().createdAt == requestTime() &&
                    incoming().status in ['pending', 'submitted', 'pending_upload', 'pending_review']) || isAdmin();
      
      allow update: if isAdmin() || (isOwner(existing().userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly([
          'imageUrl', 'storagePath', 'fieldNote', 'status', 'updatedAt',
          'deckId', 'challengeId', 'userId',
          'displayName', 'username', 'entryId',
          'proofImage', 'imageStoragePath', 'missionId', // legacy mirrors
          'reviewStatus', 'submissionStatus', 'proofStatus',
          'submissionVersion', 'submissionValidatedAt'
        ]) &&
        canUseDeck(incoming().get('deckId', existing().get('deckId', ''))) &&
        incoming().status in ['pending', 'submitted', 'pending_upload', 'pending_review'] &&
        isValidEntry(incoming())
      ));
      
      allow delete: if isAdmin();
    }

    // SCORE EVENTS (Admin Only Write)
    match /scoreEvents/{eventId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    match /levelUpEvents/{eventId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // CHALLENGES
    match /challenges/{id} {
      allow get: if isSignedIn() && canUseDeck(resource.data.get('deckId', ''));
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // DECK ACCESS CONFIGS
    // Deck documents may contain invite codes and assignment metadata. Normal
    // users receive sanitized deck-access data through server APIs only.
    match /decks/{deckId} {
      allow read, write: if isAdmin();
    }

    // FIELD CHECKS (User Reports)
    match /fieldChecks/{checkId} {
      function isValidFieldCheck(data) {
        return data.keys().hasAll(['reporterUid', 'submissionId', 'missionId', 'reportedUserId', 'reason', 'note', 'status', 'createdAt', 'updatedAt']) &&
               data.reporterUid == request.auth.uid &&
               data.status == 'pending' &&
               data.createdAt == requestTime() &&
               data.updatedAt == requestTime() &&
               data.note.size() >= 5 &&
               data.note.size() <= 2000;
      }
      allow get: if isSignedIn() && (
        isAdmin() ||
        resource.data.reporterUid == request.auth.uid || 
        resource.data.reportedUserId == request.auth.uid
      );
      allow list: if isAdmin(); // Only admins can list all checks.
      
      allow create: if isSignedIn() && isValidFieldCheck(incoming());
      allow update: if isAdmin();
    }

    // BALLOT CANDIDATES (Source of truth for Weekly Voting Hub)
    match /ballotCandidates/{candidateId} {
      function isValidCandidate(data) {
        return data.keys().hasAll(['id', 'entryId', 'userId', 'userName', 'tripId', 'tripTitle', 'proofImage', 'fieldNote', 'weekNumber', 'seasonId', 'addedAt']) &&
               data.id is string &&
               data.entryId is string &&
               data.userId is string &&
               data.userName is string &&
               data.tripId is string &&
               data.tripTitle is string &&
               data.proofImage is string &&
               data.fieldNote is string &&
               data.weekNumber is int &&
               data.seasonId is string;
      }
      allow read: if isApproved();
      allow create: if isAdmin() && isValidCandidate(incoming());
      allow update, delete: if isAdmin();
    }

    // WEEKLY BALLOTS SYSTEM & IN-LINE SUBCOLLECTIONS
    match /weeklyBallots/{ballotId} {
      function isValidWeeklyBallot(data) {
        return data.keys().hasAll(['seasonId', 'weekNumber', 'cycleStartAt', 'votingOpensAt', 'votingClosesAt', 'awardsReleaseAt', 'phase', 'candidateEntryIds', 'categoryCandidateMap', 'totalCandidates', 'isGenerated', 'isLocked', 'generatedAt']) &&
               data.seasonId is string &&
               data.weekNumber is int &&
               data.phase in ['submission', 'voting', 'awards'] &&
               data.candidateEntryIds is list &&
               data.categoryCandidateMap is map &&
               data.totalCandidates is int &&
               data.isGenerated is bool &&
               data.isLocked is bool;
      }
      allow read: if isApproved();
      allow create: if isAdmin() && isValidWeeklyBallot(incoming());
      allow update: if isAdmin() && isValidWeeklyBallot(incoming());
      allow delete: if isAdmin();

      match /candidates/{entryId} {
        function isValidWeeklyBallotCandidate(data) {
          return data.keys().hasAll(['entryId', 'userId', 'displayName', 'photoUrl', 'missionId', 'missionTitle', 'deckId', 'approvedAt', 'submittedAt', 'eligibleWeekNumber', 'seasonId', 'categories', 'voteCountByCategory', 'totalVotes', 'isEligible', 'createdAt', 'updatedAt']) &&
                 data.entryId is string &&
                 data.userId is string &&
                 data.displayName is string &&
                 data.photoUrl is string &&
                 data.missionId is string &&
                 data.missionTitle is string &&
                 data.deckId is string &&
                 data.eligibleWeekNumber is int &&
                 data.seasonId is string &&
                 data.categories is list &&
                 data.voteCountByCategory is map &&
                 data.totalVotes is int &&
                 data.isEligible is bool;
        }

        allow read: if isApproved();
        allow create: if isAdmin() && 
                         isValidWeeklyBallotCandidate(incoming()) && 
                         get(/databases/$(database)/documents/entries/$(entryId)).data.status == 'approved';
        allow update: if isAdmin() && isValidWeeklyBallotCandidate(incoming());
        allow delete: if isAdmin();
      }
    }

    // VOTES (Accolades)
    match /votes/{voteId} {
      function isValidVote(data) {
        return data.keys().hasAll(['userId', 'entryId', 'weekNumber', 'seasonId', 'category', 'createdAt']) &&
               data.userId == request.auth.uid &&
               data.createdAt == requestTime();
      }
      allow read: if isApproved() && (
        isAdmin() ||
        resource == null ||
        resource.data.userId == request.auth.uid
      );
      // Vote writes are server-owned through /api/voting/weekly/vote.
      allow create, update: if false;
      allow delete: if isAdmin();
    }

    // SABOTAGE EVENTS
    match /activeSabotages/{id} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    // LEADERBOARDS (Weekly Summaries)
    match /weeklySummaries/{id} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    // CANONICAL WEEKLY VOTING CYCLES
    match /votingCycles/{cycleId} {
      allow read: if isApproved();
      allow create, update, delete: if isAdmin();

      match /ballots/{ballotId} {
        allow read: if isApproved();
        allow create, update, delete: if isAdmin();

        match /entries/{proofId} {
          allow read: if isApproved() && (
            isAdmin() ||
            (
              resource.data.get('isEligible', false) == true &&
              resource.data.get('isDisqualified', false) != true
            )
          );
          allow create, update, delete: if isAdmin();
        }

        match /votes/{voterId} {
          allow read: if isApproved() && (
            isAdmin() ||
            voterId == request.auth.uid ||
            resource.data.get('voterId', resource.data.get('userId', '')) == request.auth.uid
          );
          // Vote writes are server-owned through /api/voting/weekly/vote.
          allow create, update, delete: if false;
        }
      }

      match /results/{resultId} {
        allow read: if isApproved();
        allow create, update, delete: if isAdmin();
      }

      match /diagnostics/{diagnosticId} {
        allow read, write: if isAdmin();
      }
    }

    // CANONICAL WEEKLY CYCLES
    // Server/admin owned weekly cycle tree. Clients may read eligible public
    // cycle material, but they cannot create votes, mutate proof snapshots, or
    // alter finalized result snapshots directly.
    match /weeklyCycles/{weekId} {
      allow read: if isApproved();
      allow create, update, delete: if isAdmin();

      match /proofs/{entryId} {
        allow read: if isApproved() && (
          isAdmin() ||
          (
            resource.data.get('isEligible', false) == true &&
            resource.data.get('isDisqualified', false) != true
          )
        );
        allow create, update, delete: if isAdmin();
      }

      match /votes/{voteId} {
        allow read: if isApproved() && (
          isAdmin() ||
          resource.data.get('userId', resource.data.get('voterId', '')) == request.auth.uid
        );
        allow create, update, delete: if false;
      }

      match /results/{resultId} {
        allow read: if isApproved();
        allow create, update, delete: if isAdmin();
      }

      match /diagnostics/{diagnosticId} {
        allow read, write: if isAdmin();
      }
    }

    // NOTIFICATIONS
    match /notifications/{id} {
      allow read, delete: if isOwner(resource.data.userId);
      allow update: if isOwner(resource.data.userId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow create: if isAdmin();
    }

    // MODERATION REPORTS
    match /reports/{id} {
      allow create: if isSignedIn();
      allow get: if isAdmin() || (isSignedIn() && resource.data.reporterId == request.auth.uid);
      allow list: if isAdmin();
      allow update: if isAdmin();
    }

    match /susReports/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // MODERATION AUDIT (Append-only for admins)
    match /moderationAudit/{id} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    // ADMIN LOGS (Append-only for admins)
    match /adminLogs/{id} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    match /adminRepairLogs/{id} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    match /_system/{id} {
      allow read, write: if isAdmin();
    }

    // STAMPS (Collectibles)
    match /stamps/{id} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if isAdmin();
    }

    // CREWS & MEMBERS
    match /crews/{id} {
      allow read: if isApproved() && (isAdmin() || isActiveCrewMemberOf(id));
      allow write: if false;

      match /members/{userId} {
        allow read: if isApproved() && (isAdmin() || userId == request.auth.uid || isActiveCrewMemberOf(id));
        allow write: if false;
      }
    }

    match /crewSeasonZines/{id} {
      allow read: if isApproved() && canReadCrewArchive(resource.data);
      allow write: if false;

      match /nominations/{nominationId} {
        allow read: if isApproved() && (isAdmin() || isActiveCrewMemberOf(get(/databases/$(database)/documents/crewSeasonZines/$(id)).data.get('crewId', '')));
        allow write: if false;
      }
    }

    match /personalZines/{id} {
      allow read: if isApproved() && (isAdmin() || resource.data.get('ownerId', '') == request.auth.uid);
      allow write: if false;
    }

    match /zineFinalizations/{id} {
      allow read: if isApproved() && (
        isAdmin() ||
        resource.data.get('ownerId', '') == request.auth.uid ||
        resource.data.get('viewerUserIdsSnapshot', []).hasAny([request.auth.uid])
      );
      allow write: if false;
    }

    match /zineAuditLogs/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /crewInvites/{id} {
      allow get, list: if isSignedIn() && (
        isAdmin() ||
        resource.data.inviteeUserId == request.auth.uid ||
        resource.data.inviterId == request.auth.uid ||
        isCrewCaptainOf(resource.data.get('crewId', ''))
      );
      allow write: if false;
    }

    match /crewJoinRequests/{id} {
      allow get, list: if isSignedIn() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid ||
        isCrewCaptainOf(resource.data.get('crewId', ''))
      );
      allow write: if false;
    }

    match /crewInviteRedemptions/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.get('userId', '') == request.auth.uid);
      allow write: if false;
    }

    match /crewArchiveEntries/{id} {
      allow read: if isApproved() && (isAdmin() || isActiveCrewMemberOf(resource.data.get('crewId', '')));
      allow write: if false;
    }

    match /personalArchiveEntries/{id} {
      allow read: if isApproved() && (isAdmin() || resource.data.get('ownerId', '') == request.auth.uid);
      allow write: if false;
    }

    match /crewLore/{id} {
      allow read: if isApproved() && (isAdmin() || isActiveCrewMemberOf(resource.data.get('crewId', id)));
      allow write: if false;
    }

    match /crewArtifacts/{id} {
      allow read: if isApproved() && (isAdmin() || isActiveCrewMemberOf(resource.data.get('crewId', '')));
      allow write: if false;
    }

    match /crewDispatches/{id} {
      allow read: if isApproved() && (isAdmin() || isActiveCrewMemberOf(resource.data.get('crewId', '')));
      allow write: if false;
    }

    match /crewAuditLogs/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }
    
    // PROOF SYSTEM
    match /proofRequirements/{id} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    // AI CONTROL ACTIONS (SERVER-ONLY WRITES)
    match /proofs/{proofId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /aiUsageLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /aiDailyCounters/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow write: if false;
    }

    match /likes/{likeId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /reactions/{reactionId} {
      // reactionId pattern: entryId_userId_emoji
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /proofReviews/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isApproved() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /proofChecks/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if isApproved() && incoming().userId == request.auth.uid;
      allow delete: if isAdmin();
    }
    
    // TRIBUNAL
    match /tribunalCases/{caseId} {
      allow read: if isTribunalEligible() && resource.data.status in ['open', 'closed'];
      allow create, update, delete: if false;
    }

    match /tribunalCasePrivate/{caseId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /tribunalVotes/{voteId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      // Tribunal vote writes are server-owned through /api/tribunal/vote.
      allow create, update: if false;
    }

    match /tribunalVoteAudit/{voteId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /tribunalResults/{caseId} {
      allow read: if isTribunalEligible();
      allow write: if false;
    }

    match /susReportCounters/{counterId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /susAbuseSignals/{userId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Global Catch-all Deny at the very end
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
