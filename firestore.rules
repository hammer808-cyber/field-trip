rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // 0. PUBLIC CONFIGS (ALLOW READ ALWAYS)
    // =========================================================================
    match /appConfig/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /fieldSignals/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /seasons/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // =========================================================================
    // 1. HELPERS & PILLARS
    // =========================================================================

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        // Allow developer email even if verified is null (some providers in preview)
        (request.auth.token.email == 'hammer808@gmail.com' && (request.auth.token.email_verified == true || request.auth.token.email_verified == null)) ||
        // Hardcoded UID for the developer to ensure access if token email is tricky
        (request.auth.uid == 'oae0GwP7mpcUX7i93AeDGd22VNu2') ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    function isApproved() {
      return isSignedIn() && (
        isAdmin() ||
        // Allow if user exists and is approved
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('accessStatus', 'pending') == 'approved') ||
        // Always allow if they have a profile during beta (simplified gate)
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        true
      );
    }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isValidAccessCode(data) {
      return data.keys().hasAll(['active', 'maxUses', 'currentUses', 'createdAt']) &&
             data.active is bool &&
             data.maxUses is int &&
             data.currentUses is int &&
             data.createdAt is timestamp;
    }
    function canUseAccessCode(codeId) {
      let code = get(/databases/$(database)/documents/accessCodes/$(codeId)).data;
      let usage = code.get('currentUses', 0) > 0 ? code.currentUses : code.get('uses', 0);
      return code.active == true && (code.maxUses == 0 || usage < code.maxUses);
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function requestTime() { return request.time; }

    // =========================================================================
    // 2. CATCH-ALL DENY (Moved to end for better matching behavior)
    // =========================================================================
    // match /{document=**} { allow read, write: if false; }

    // =========================================================================
    // 3. COLLECTIONS
    // =========================================================================

    // ADMIN ACCESS
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // USERNAMES (Unique Mapping)
    match /usernames/{username} {
      function isValidUsername(data) {
        return data.keys().hasAll(['userId', 'createdAt']) &&
               data.keys().size() == 2 &&
               data.userId == request.auth.uid &&
               data.createdAt == requestTime();
      }
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidUsername(incoming()) && username.size() <= 32;
    }

    // ACCESS CODES (Invite Codes)
    match /accessCodes/{code} {
      // Not publicly readable (list), but getable if you know the code
      allow get: if true; 
      allow list: if false;
      allow update: if isSignedIn() && (
        // Case 1: Pre-auth validation (Increment uses/currentUses and server-side tracking)
        (
          incoming().diff(existing()).affectedKeys().hasOnly(['currentUses', 'usedBy', 'uses', 'lastValidatedAt']) &&
          (existing().maxUses == 0 || (existing().get('currentUses', 0) < existing().maxUses || existing().get('uses', 0) < existing().maxUses))
        ) ||
        // Case 2: Post-auth registration tracking
        (
          incoming().diff(existing()).affectedKeys().hasOnly(['lastRegisteredAt', 'lastRegisteredUser'])
        )
      );
      allow create: if isAdmin() && isValidAccessCode(incoming()) && isValidId(code);
      allow delete: if isAdmin();
    }

    // USERS (Identity & RBAC)
    match /users/{uId} {
      // allow get is more robust for non-existent profiles during registration
      allow get: if isSignedIn() && (uId == request.auth.uid || isAdmin());
      allow list: if isSignedIn();
      allow create, update: if isSignedIn() && (uId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
      
      // Allow recursive access to own subcollections (blocks, legalConsents, etc.)
      match /{allPaths=**} {
        allow read, write: if isSignedIn() && (uId == request.auth.uid || isAdmin());
      }
    }

    match /userPrefs/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /badgeProgress/{id} {
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && existing().userId == request.auth.uid && (
        incoming().diff(existing()).affectedKeys().hasOnly(['fragmentCount', 'isUnlocked', 'unlockedAt', 'lastFragmentEarnedAt'])
      );
      allow delete: if isAdmin();
    }

    match /observations/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && existing().userId == request.auth.uid && (
        incoming().diff(existing()).affectedKeys().hasOnly(['isDismissed'])
      );
      allow delete: if isAdmin();
    }

    match /badgeFragments/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ENTRIES (Submissions)
    match /entries/{entryId} {
      function isValidEntry(data) {
        return data.keys().hasAll(['userId', 'status', 'createdAt']) &&
               data.userId == request.auth.uid &&
               data.status in ['submitted', 'available', 'approved', 'rejected'] &&
               (data.fieldNote == null || data.fieldNote.size() <= 1000);
      }

      allow read: if isApproved() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      allow create: if isApproved() && isValidId(entryId) && isValidEntry(incoming()) &&
                    incoming().createdAt == requestTime() &&
                    incoming().status == 'submitted';
      
      allow update: if (isOwner(existing().userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['proofImage', 'fieldNote', 'status', 'updatedAt']) &&
        incoming().status == 'submitted' &&
        isValidEntry(incoming())
      )) || isAdmin();
      
      allow delete: if isAdmin();
    }

    // SCORE EVENTS (Admin Only Write)
    match /scoreEvents/{eventId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // CHALLENGES
    match /challenges/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // FIELD CHECKS (User Reports)
    match /fieldChecks/{checkId} {
      function isValidFieldCheck(data) {
        return data.keys().hasAll(['reporterId', 'targetId', 'targetUserId', 'reason', 'status', 'createdAt']) &&
               data.reporterId == request.auth.uid &&
               data.status in ['open', 'dismissed'] &&
               data.createdAt == requestTime() &&
               (data.get('details', '').size() <= 2000);
      }
      allow get: if isSignedIn() && (
        isAdmin() ||
        resource.data.reporterId == request.auth.uid || 
        resource.data.targetUserId == request.auth.uid
      );
      allow list: if isAdmin(); // Only admins can list all checks.
      
      allow create: if isSignedIn() && isValidId(checkId) && isValidFieldCheck(incoming());
      allow update: if (isAdmin()) || (
        isApproved() && resource.data.targetUserId == request.auth.uid &&
        incoming().diff(existing()).affectedKeys().hasOnly(['defense', 'defenseSubmittedAt', 'updatedAt']) &&
        (incoming().get('defense', '').size() <= 2000)
      );
    }

    // VOTES (Accolades)
    match /votes/{voteId} {
      function isValidVote(data) {
        return data.keys().hasAll(['userId', 'entryId', 'weekNumber', 'category', 'createdAt']) &&
               data.userId == request.auth.uid &&
               data.createdAt == requestTime();
      }
      allow read: if isApproved();
      // voteId: userId_week_category prevents duplicates
      allow create: if isApproved() && 
                    voteId == (request.auth.uid + "_w" + incoming().weekNumber + "_" + incoming().category) &&
                    isValidVote(incoming()) &&
                    get(/databases/$(database)/documents/entries/$(incoming().entryId)).data.userId != request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // SABOTAGE EVENTS
    match /activeSabotages/{id} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    // LEADERBOARDS (Weekly Summaries)
    match /weeklySummaries/{id} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    // NOTIFICATIONS
    match /notifications/{id} {
      allow read, delete: if isOwner(resource.data.userId);
      allow update: if isOwner(resource.data.userId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow create: if isAdmin();
    }

    // MODERATION REPORTS
    match /reports/{id} {
      allow create: if isSignedIn();
      allow get: if isAdmin() || (isSignedIn() && resource.data.reporterId == request.auth.uid);
      allow list: if isAdmin();
      allow update: if isAdmin();
    }

    // MODERATION AUDIT (Append-only for admins)
    match /moderationAudit/{id} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    // ADMIN LOGS (Append-only for admins)
    match /adminLogs/{id} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    // STAMPS (Collectibles)
    match /stamps/{id} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if isAdmin();
    }

    // CREWS & MEMBERS
    match /crews/{id} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }
    
    // PROOF SYSTEM
    match /proofRequirements/{id} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /proofReviews/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isApproved() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /proofChecks/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if isApproved() && incoming().userId == request.auth.uid;
      allow delete: if isAdmin();
    }
    
    // Global Catch-all Deny at the very end
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
