<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 600" width="100%" height="100%">
  <defs>
    <!-- Holographic Slick Linear Gradients -->
    <linearGradient id="holoWaves" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#FFC2EB" />
      <stop offset="25%" stop-color="#99E5FF" />
      <stop offset="50%" stop-color="#C2FFD4" />
      <stop offset="75%" stop-color="#FDFFA6" />
      <stop offset="100%" stop-color="#EAA6FF" />
    </linearGradient>
    <linearGradient id="puffyPink" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#FF8AD5" />
      <stop offset="50%" stop-color="#FF47B1" />
      <stop offset="100%" stop-color="#D9168B" />
    </linearGradient>
    <linearGradient id="puffyGloss" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="white" stop-opacity="0.8" />
      <stop offset="50%" stop-color="white" stop-opacity="0" />
    </linearGradient>
    <filter id="puffyShadow" x="-10%" y="-10%" width="120%" height="120%">
      <feDropShadow dx="3" dy="10" stdDeviation="5" flood-color="#5E003D" flood-opacity="0.25" />
    </filter>
    <filter id="stickerGlow" x="-10%" y="-10%" width="125%" height="125%">
      <feDropShadow dx="0" dy="4" stdDeviation="4" flood-color="#a33273" flood-opacity="0.15" />
    </filter>
  </defs>

  <!-- Base Card Frame -->
  <rect x="0" y="0" width="400" height="600" rx="24" fill="url(#holoWaves)" stroke="#111" stroke-width="6" />

  <!-- Holographic organic waves/swirls patterns in background -->
  <path d="M -50,150 Q 120,50 300,180 T 500,200 L 500,600 L -50,600 Z" fill="#FFE5F5" fill-opacity="0.25" />
  <path d="M -50,250 Q 80,350 250,220 T 500,380 L 500,600 L -50,600 Z" fill="#EBF9FF" fill-opacity="0.3" />

  <!-- Outer Grid Border Design Lane -->
  <rect x="12" y="12" width="376" height="576" rx="16" fill="none" stroke="#fff" stroke-width="2" stroke-opacity="0.6" />
  <rect x="16" y="16" width="368" height="568" rx="12" fill="none" stroke="#e07cb1" stroke-width="1.5" stroke-opacity="0.15" stroke-dasharray="3,3" />

  <!-- Little Decorative Sunburst / Star Flares -->
  <g transform="translate(320, 150)" opacity="0.8">
    <path d="M 0,-15 L 2.5,-3 L 15,0 L 2.5,3 L 0,15 L -2.5,3 L -15,0 L -2.5,-3 Z" fill="#FF70AB" />
    <circle cx="0" cy="0" r="3" fill="#FFF" />
  </g>
  <g transform="translate(80, 390)" opacity="0.6">
    <path d="M 0,-10 L 2,-2 L 10,0 L 2,2 L 0,10 L -2,2 L -10,0 L -2,-2 Z" fill="#FFDF00" />
  </g>
  <g transform="translate(340, 420)" opacity="0.7">
    <path d="M 0,-12 L 2,-2 L 12,0 L 2,2 L 0,12 L -2,2 L -12,0 L -2,-2 Z" fill="#FFF" />
  </g>

  <!-- Left Ribbon Badge FT-01 (Pink theme with micro palm tree) -->
  <g transform="translate(16, -2)">
    <path d="M 0,0 L 80,0 L 80,95 L 40,78 L 0,95 Z" fill="#FFA3D5" stroke="#111" stroke-width="2.5" />
    <path d="M 6,0 L 74,0 L 74,83 L 40,68 L 6,83 Z" fill="#FFFDF9" />
    <!-- Mini emblem -->
    <circle cx="40" cy="30" r="16" fill="none" stroke="#FF5AA5" stroke-width="1.5" />
    <!-- Simple vector palm tree in badge -->
    <path d="M 40,40 Q 38,30 36,22 L 39,22 Q 41,30 40,40 Z" fill="#FF5AA5" />
    <path d="M 37,23 Q 32,20 28,24" fill="none" stroke="#FF5AA5" stroke-width="1.5" stroke-linecap="round" />
    <path d="M 39,22 Q 40,16 45,18" fill="none" stroke="#FF5AA5" stroke-width="1.5" stroke-linecap="round" />
    <text x="40" y="60" fill="#E61A80" font-family="'Space Grotesk', sans-serif" font-size="12" font-weight="950" text-anchor="middle" letter-spacing="1">FT-01</text>
  </g>

  <!-- Main Central 3D Puffy Bubble Badge -->
  <g transform="translate(200, 260)" filter="url(#puffyShadow)">
    <!-- White outer puffy pillow contour border -->
    <rect x="-154" y="-74" width="308" height="148" rx="44" fill="#FFF" stroke="#111" stroke-width="4.5" />
    
    <!-- Bubble text backing background in gradient pink -->
    <rect x="-146" y="-66" width="292" height="132" rx="36" fill="url(#puffyPink)" />
    
    <!-- Gloss highlight layer (creates 3D plastic look) -->
    <rect x="-140" y="-60" width="280" height="55" rx="26" fill="url(#puffyGloss)" />

    <!-- Highly Puffy Title Text - 3D effect via twin layers -->
    <!-- Pinkish Backdrop text -->
    <text x="0" y="4" fill="#6B0043" font-family="'Space Grotesk', 'Helvetica Neue', Arial, sans-serif" font-size="34" font-weight="950" text-anchor="middle" letter-spacing="1" transform="skewX(-5)">HEATWAVE</text>
    <text x="0" y="44" fill="#6B0043" font-family="'Space Grotesk', 'Helvetica Neue', Arial, sans-serif" font-size="34" font-weight="950" text-anchor="middle" letter-spacing="1" transform="skewX(-5)">RECEIPTS</text>

    <!-- Warm pink foreground text -->
    <text x="0" y="0" fill="#FFF" font-family="'Space Grotesk', 'Helvetica Neue', Arial, sans-serif" font-size="34" font-weight="950" text-anchor="middle" letter-spacing="1" transform="skewX(-5)">HEATWAVE</text>
    <text x="0" y="40" fill="#FFF" font-family="'Space Grotesk', 'Helvetica Neue', Arial, sans-serif" font-size="34" font-weight="950" text-anchor="middle" letter-spacing="1" transform="skewX(-5)">RECEIPTS</text>
  </g>

  <!-- Puffy Orange Summer Seasonal Ribbon Sticker -->
  <g transform="translate(200, 360)" filter="url(#stickerGlow)">
    <rect x="-100" y="-18" width="200" height="36" rx="18" fill="#FF8E00" stroke="#FFF" stroke-width="3" />
    <rect x="-100" y="-18" width="200" height="36" rx="18" fill="none" stroke="#111" stroke-width="4" />
    <text x="0" y="5" fill="#FFF" font-family="'Space Grotesk', sans-serif" font-size="11" font-weight="900" letter-spacing="2" text-anchor="middle">SUMMER SEASONAL</text>
  </g>

  <!-- Bottom Brand Text -->
  <g transform="translate(200, 500)">
    <line x1="-120" y1="-26" x2="-80" y2="-26" stroke="#C30F7F" stroke-width="1.5" stroke-opacity="0.3" />
    <text x="0" y="-20" fill="#C30F7F" font-family="'Space Grotesk', sans-serif" font-size="13" font-weight="900" letter-spacing="5" text-anchor="middle">FIELDTRIP EXPEDITIONS</text>
    <line x1="80" y1="-26" x2="120" y2="-26" stroke="#C30F7F" stroke-width="1.5" stroke-opacity="0.3" />
    
    <text x="0" y="0" fill="#1C3D32" font-family="'JetBrains Mono', monospace" font-size="9" font-weight="900" letter-spacing="3" text-anchor="middle" opacity="0.6">FT-01 DIRECTIVE EXPEDITION</text>

    <!-- Waves decorations footer -->
    <path d="M -60,18 C -30,12 -30,24 0,18 C 30,12 30,24 60,18" fill="none" stroke="#C30F7F" stroke-width="2.5" stroke-linecap="round" stroke-opacity="0.4" />
  </g>
</svg>
