<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 600" width="100%" height="100%">
  <defs>
    <!-- Sky / Ocean / Sand Gradients -->
    <linearGradient id="skyGrad" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#FFF2CE" />
      <stop offset="40%" stop-color="#FFDDAD" />
      <stop offset="100%" stop-color="#FFA89E" />
    </linearGradient>
    <linearGradient id="oceanBlue" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#2ED2E5" />
      <stop offset="100%" stop-color="#1494BC" />
    </linearGradient>
    <linearGradient id="sandYellow" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#FFEBB2" />
      <stop offset="100%" stop-color="#EAC180" />
    </linearGradient>
    <linearGradient id="puffyCoral" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#FF9782" />
      <stop offset="100%" stop-color="#E05435" />
    </linearGradient>
    <linearGradient id="puffyTeal" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#26DFCD" />
      <stop offset="100%" stop-color="#0E9F90" />
    </linearGradient>
    <linearGradient id="stickerWhite" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#FFFFFF" />
      <stop offset="100%" stop-color="#F2EFDF" />
    </linearGradient>
    <filter id="coastalDrop" x="-10%" y="-10%" width="120%" height="120%">
      <feDropShadow dx="3" dy="8" stdDeviation="4" flood-color="#55220F" flood-opacity="0.25" />
    </filter>
  </defs>

  <!-- Frame -->
  <rect x="0" y="0" width="400" height="600" rx="24" fill="url(#skyGrad)" stroke="#111" stroke-width="6" />

  <!-- Background Sand Dune Curve (Bottom third) -->
  <path d="M -50,420 Q 150,380 450,440 L 450,600 L -50,600 Z" fill="url(#sandYellow)" stroke="#111" stroke-width="2" />

  <!-- Background Ocean turquoise swell -->
  <path d="M -50,440 L 450,410 L 450,490 Q 200,520 -50,470 Z" fill="url(#oceanBlue)" opacity="0.8" />

  <!-- Outer Border Lines -->
  <rect x="12" y="12" width="376" height="576" rx="16" fill="none" stroke="#FFF" stroke-width="2" stroke-opacity="0.7" />

  <!-- Left Ribbon Badge FT-03 (Mint-Green Theme) -->
  <g transform="translate(16, -2)">
    <path d="M 0,0 L 80,0 L 80,95 L 40,78 L 0,95 Z" fill="#8CE0D0" stroke="#111" stroke-width="2.5" />
    <path d="M 6,0 L 74,0 L 74,83 L 40,68 L 6,83 Z" fill="#FFFDF9" />
    <!-- Mini emblem -->
    <circle cx="40" cy="30" r="16" fill="none" stroke="#227C6C" stroke-width="1.5" />
    <!-- Wave and Palm trees mini vectors inside stamp -->
    <path d="M 33,35 Q 40,30 47,35" fill="none" stroke="#227C6C" stroke-width="1.5" />
    <path d="M 40,25 Q 41,18 45,19" fill="none" stroke="#227C6C" stroke-width="1.2" />
    <text x="40" y="60" fill="#1C6154" font-family="'Space Grotesk', sans-serif" font-size="12" font-weight="950" text-anchor="middle" letter-spacing="1">FT-03</text>
  </g>

  <!-- 3D Puffy SOCAL SUMMER Glossy Cartoon Styling Header -->
  <g id="so-cal-summer-sticker-group" transform="translate(200, 220)" filter="url(#coastalDrop)">
    <!-- White paper sticker backdrop layer -->
    <path d="M-135,-82 Q-100,-86 -5,-82 Q70,-86 135,-82 Q160,-50 155,-10 Q160,25 152,72 Q80,78 -5,72 Q-75,78 -135,72 Q-160,35 -152,-15 Q-160,-50 -135,-82 Z" fill="#FFF" stroke="#111" stroke-width="4.5" />
    
    <!-- SOCAL lettering (Coral Pink) -->
    <g transform="translate(0, -32)">
      <!-- Backdrop shadowing structure -->
      <text x="4" y="4" fill="#8C1E0A" font-family="'Space Grotesk', 'Comic Sans MS', sans-serif" font-size="44" font-weight="950" text-anchor="middle" letter-spacing="1">SOCAL</text>
      <!-- Foreground -->
      <text x="0" y="0" fill="url(#puffyCoral)" stroke="#5E0D00" stroke-width="1.5" font-family="'Space Grotesk', 'Comic Sans MS', sans-serif" font-size="44" font-weight="950" text-anchor="middle" letter-spacing="1">SOCAL</text>
    </g>

    <!-- SUMMER lettering (Mint Teal) -->
    <g transform="translate(0, 24)">
      <!-- Backdrop -->
      <text x="4" y="4" fill="#0A5B51" font-family="'Space Grotesk', 'Comic Sans MS', sans-serif" font-size="44" font-weight="950" text-anchor="middle" letter-spacing="1">SUMMER</text>
      <!-- Foreground -->
      <text x="0" y="0" fill="url(#puffyTeal)" stroke="#023E37" stroke-width="1.5" font-family="'Space Grotesk', 'Comic Sans MS', sans-serif" font-size="44" font-weight="950" text-anchor="middle" letter-spacing="1">SUMMER</text>
    </g>
  </g>

  <!-- Illustrated Beach Vignette: Wave, Sun, Palm Tree, Cactus -->
  <g transform="translate(200, 480)" filter="url(#coastalDrop)">
    <!-- Main Badge Backdrop -->
    <path d="M -110,-5 Q -130,-45 -95,-65 Q 0,-95 95,-65 Q 130,-45 110,-5 Q 110,45 -5,45 Q -110,45 -110,-5 Z" fill="url(#stickerWhite)" stroke="#111" stroke-width="4.5" />

    <!-- Cute Sun -->
    <g transform="translate(0, -45)">
      <circle cx="0" cy="0" r="18" fill="#FFC300" stroke="#111" stroke-width="2.5" />
      <path d="M 0,-25 L 0,-20 M 0,20 L 0,25 M -25,0 L -20,0 M 20,0 L 25,0 M -16,-16 L -12,-12 M 12,12 L 16,16 M -16,16 L -12,12 M 12,-12 L 16,-16" stroke="#111" stroke-width="3" stroke-linecap="round" />
    </g>

    <!-- Waves Curls (Left side) -->
    <g transform="translate(-75, -5)">
      <path d="M -30,25 C -5,25 0,-15 -20,-20 C -40,-25 -30,5 -5,5 C 10,5 5,-25 -20,-25 L -35,25 Z" fill="#2ED2E5" stroke="#111" stroke-width="2.5" />
      <path d="M -20,25 C -5,25 2,5 -10,0 C -20,-5 -15,10 -5,10" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" />
    </g>
    
    <!-- Palm Tree (Right Center) -->
    <g transform="translate(45, -5)">
      <!-- Trunk -->
      <path d="M 0,30 Q -5,5 -2,-25 L 5,-25 Q 2,5 5,30 Z" fill="#A06A42" stroke="#111" stroke-width="2.5" />
      <line x1="1" y1="15" x2="6" y2="15" stroke="#111" stroke-width="1.5" />
      <line x1="-1" y1="0" x2="4" y2="0" stroke="#111" stroke-width="1.5" />
      <line x1="-2" y1="-15" x2="3" y2="-15" stroke="#111" stroke-width="1.5" />
      <!-- Fronds -->
      <path d="M 1,-25 Q -10,-40 -25,-30 M 1,-25 Q 15,-45 28,-35 M 1,-25 Q -20,-20 -28,-10 M 1,-25 Q 20,-20 28,-10 M 1,-25 Q 0,-50 0,-15" fill="none" stroke="#25A03A" stroke-width="4.5" stroke-linecap="round" />
      <path d="M 1,-25 Q -10,-40 -25,-30 M 1,-25 Q 15,-45 28,-35 M 1,-25 Q -20,-20 -28,-10 M 1,-25 Q 20,-20 28,-10" fill="none" stroke="#FFF" stroke-width="1.5" stroke-linecap="round" />
    </g>

    <!-- Desert Cactus on Beach (Right Corner) -->
    <g transform="translate(85, 10) scale(0.85)">
      <!-- Main body -->
      <rect x="-6" y="-30" width="12" height="40" rx="6" fill="#1B8749" stroke="#111" stroke-width="2.5" />
      <!-- Left limb -->
      <path d="M -5,-15 Q -18,-15 -18,-25" fill="none" stroke="#111" stroke-width="7.5" stroke-linecap="round" />
      <path d="M -5,-15 Q -18,-15 -18,-25" fill="none" stroke="#1B8749" stroke-width="3" stroke-linecap="round" />
      <!-- Right limb -->
      <path d="M 5,-8 Q 18,-8 18,-20" fill="none" stroke="#111" stroke-width="7.5" stroke-linecap="round" />
      <path d="M 5,-8 Q 18,-8 18,-20" fill="none" stroke="#1B8749" stroke-width="3" stroke-linecap="round" />
    </g>
  </g>

  <!-- Bottom subtitle -->
  <g transform="translate(200, 565)">
    <text x="0" y="0" fill="#E24A22" font-family="'Space Grotesk', sans-serif" font-size="12" font-weight="900" letter-spacing="4" text-anchor="middle">SOUTHERN CALIFORNIA COOP</text>
  </g>
</svg>
