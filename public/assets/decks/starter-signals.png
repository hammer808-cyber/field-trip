<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 600" width="100%" height="100%">
  <defs>
    <linearGradient id="scoutGrad" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#1F2E23" />
      <stop offset="50%" stop-color="#0E1610" />
      <stop offset="100%" stop-color="#050806" />
    </linearGradient>
    <radialGradient id="radarPulse" cx="50%" cy="40%" r="50%">
      <stop offset="0%" stop-color="#BEF264" stop-opacity="0.3" />
      <stop offset="60%" stop-color="#BEF264" stop-opacity="0.05" />
      <stop offset="100%" stop-color="# BEF264" stop-opacity="0" />
    </radialGradient>
  </defs>

  <!-- Frame -->
  <rect x="0" y="0" width="400" height="600" rx="24" fill="url(#scoutGrad)" stroke="#111" stroke-width="6" />

  <!-- Radar circle grid -->
  <circle cx="200" cy="230" r="140" fill="url(#radarPulse)" stroke="#BEF264" stroke-width="1.5" stroke-opacity="0.1" />
  <circle cx="200" cy="230" r="100" fill="none" stroke="#BEF264" stroke-width="1" stroke-opacity="0.2" />
  <circle cx="200" cy="230" r="60" fill="none" stroke="#BEF264" stroke-width="1" stroke-opacity="0.3" />
  <circle cx="200" cy="230" r="20" fill="none" stroke="#BEF264" stroke-width="1" stroke-opacity="0.4" />

  <!-- Radar Crosshairs -->
  <line x1="200" y1="70" x2="200" y2="390" stroke="#BEF264" stroke-width="1" stroke-opacity="0.2" />
  <line x1="40" y1="230" x2="360" y2="230" stroke="#BEF264" stroke-width="1" stroke-opacity="0.2" stroke-dasharray="3,3" />

  <!-- Signal Pulses/Dots -->
  <circle cx="280" cy="170" r="6" fill="#BEF264" />
  <circle cx="280" cy="170" r="15" fill="none" stroke="#BEF264" stroke-width="2" stroke-opacity="0.5" />
  
  <circle cx="120" cy="280" r="4" fill="#BEF264" fill-opacity="0.7" />
  <circle cx="150" cy="160" r="5" fill="#BEF264" fill-opacity="0.8" />

  <!-- Outer Border Design Lines -->
  <rect x="12" y="12" width="376" height="576" rx="16" fill="none" stroke="#BEF264" stroke-width="1.5" stroke-opacity="0.2" />

  <!-- Angle Bracket Corners representing "scoping view" -->
  <path d="M 30,50 L 30,30 L 50,30" fill="none" stroke="#BEF264" stroke-width="3" stroke-linecap="square" />
  <path d="M 370,50 L 370,30 L 350,30" fill="none" stroke="#BEF264" stroke-width="3" stroke-linecap="square" />
  <path d="M 30,550 L 30,570 L 50,570" fill="none" stroke="#BEF264" stroke-width="3" stroke-linecap="square" />
  <path d="M 370,550 L 370,570 L 350,570" fill="none" stroke="#BEF264" stroke-width="3" stroke-linecap="square" />

  <!-- Left Ribbon Badge FT-SS -->
  <g transform="translate(16, -2)">
    <path d="M 0,0 L 80,0 L 80,48 L 40,32 L 0,48 Z" fill="#BEF264" stroke="#111" stroke-width="2.5" />
    <text x="40" y="24" fill="#0C160F" font-family="'JetBrains Mono', monospace" font-size="14" font-weight="900" text-anchor="middle" letter-spacing="1">FT-SS</text>
  </g>

  <!-- Central Pulse Wave Radar sweep -->
  <g transform="translate(200, 230)">
    <polygon points="0,0 80,-120 120,-80" fill="url(#radarPulse)" fill-opacity="0.4" />
    <circle cx="0" cy="0" r="5" fill="#BEF264" />
    <circle cx="0" cy="0" r="10" fill="none" stroke="#BEF264" stroke-width="1.5" stroke-opacity="0.7" />
  </g>

  <!-- Typography Area -->
  <g id="text-container" transform="translate(200, 470)">
    <line x1="-120" y1="-26" x2="-80" y2="-26" stroke="#BEF264" stroke-width="1.5" stroke-opacity="0.4" />
    <text x="0" y="-20" fill="#BEF264" fill-opacity="0.7" font-family="'Space Grotesk', 'Inter', sans-serif" font-size="13" font-weight="bold" letter-spacing="4" text-anchor="middle">CALIBRATION PROTOCOL</text>
    <line x1="80" y1="-26" x2="120" y2="-26" stroke="#BEF264" stroke-width="1.5" stroke-opacity="0.4" />
    
    <text x="0" y="-2" fill="#BEF264" fill-opacity="0.4" font-family="'Space Grotesk', 'Inter', sans-serif" font-size="10" font-weight="950" letter-spacing="6" text-anchor="middle">FIRST PORT SIGNALS</text>
    
    <!-- Large slab header -->
    <text x="0" y="55" fill="#BEF264" font-family="'Space Grotesk', 'Helvetica Neue', sans-serif" font-size="40" font-weight="900" letter-spacing="1" text-anchor="middle">STARTER SIGNALS</text>
    
    <rect x="-100" y="78" width="200" height="2" fill="#BEF264" fill-opacity="0.2" />
    <text x="0" y="94" fill="#BEF264" fill-opacity="0.5" font-family="'JetBrains Mono', monospace" font-size="9" font-weight="500" letter-spacing="3" text-anchor="middle">ONBOARDING • ACTIVE DECK</text>
  </g>
</svg>
