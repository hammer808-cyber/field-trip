diff --git a/src/services/repairService.ts b/src/services/repairService.ts
index 7119439..39b347f 100644
--- a/src/services/repairService.ts
+++ b/src/services/repairService.ts
@@ -62,6 +62,23 @@ export interface DiagnosticsReport {
   lastRepairRunTimestamp: string;
 }
 
+async function getRepairErrorMessage(response: Response, fallback: string): Promise<string> {
+  const rawText = await response.text().catch(() => '');
+  let parsed: any = null;
+  try {
+    parsed = rawText ? JSON.parse(rawText) : null;
+  } catch {
+    parsed = null;
+  }
+
+  const message = parsed?.message || parsed?.error || rawText || fallback;
+  if (message === '500_FOUND' || message === 'HTTP error 500') {
+    return 'Server repair route failed. Check the dev server console and Firebase Admin credentials.';
+  }
+
+  return message;
+}
+
 /**
  * Repairs the mission state for a specific user using the secure backend utility.
  */
@@ -74,8 +91,7 @@ export async function repairUserMissionState(uid: string, dryRun: boolean = fals
     });
 
     if (!response.ok) {
-      const errData = await response.json().catch(() => ({}));
-      throw new Error(errData.message || errData.error || `HTTP error ${response.status}`);
+      throw new Error(await getRepairErrorMessage(response, `Repair failed with HTTP ${response.status}`));
     }
 
     const raw = await response.json();
@@ -139,8 +155,7 @@ export async function repairAllUserOrphans(dryRun: boolean = true): Promise<{
     });
 
     if (!response.ok) {
-      const errData = await response.json().catch(() => ({}));
-      throw new Error(errData.message || errData.error || `HTTP error ${response.status}`);
+      throw new Error(await getRepairErrorMessage(response, `Bulk sync failed with HTTP ${response.status}`));
     }
 
     const raw = await response.json();
@@ -185,8 +200,7 @@ export async function repairStrandedStarterUsers(dryRun: boolean = true, softRes
     });
 
     if (!response.ok) {
-      const errData = await response.json().catch(() => ({}));
-      throw new Error(errData.message || errData.error || `HTTP error ${response.status}`);
+      throw new Error(await getRepairErrorMessage(response, `Stranded starter repair failed with HTTP ${response.status}`));
     }
 
     return response.json();
@@ -217,8 +231,7 @@ export async function getRepairDiagnostics(): Promise<DiagnosticsReport> {
   });
 
   if (!response.ok) {
-    const errData = await response.json().catch(() => ({}));
-    throw new Error(errData.message || errData.error || `HTTP error ${response.status}`);
+    throw new Error(await getRepairErrorMessage(response, `Repair diagnostics failed with HTTP ${response.status}`));
   }
 
   return response.json();
