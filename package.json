{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "test": "tsx --test --test-force-exit src/__tests__/starterDeckDraw.test.ts",
    "preview": "vite preview",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test:starter": "tsx src/__tests__/starterDeckState.test.ts",
    "test:rubric": "tsx src/__tests__/proofRubric.test.ts",
    "test:community-feed": "tsx --test src/__tests__/communityFeed.test.ts",
    "test:beta-blockers": "tsx --test src/__tests__/communityFeed.test.ts src/__tests__/routesUnlocks.test.ts",
    "test:admin-review-queue": "tsx --test src/__tests__/adminReviewQueue.test.ts",
    "test:onboarding": "tsx --test src/__tests__/onboardingClassification.test.ts",
    "test:voting-security": "tsx --test src/__tests__/weeklyVotingSecurity.test.ts src/__tests__/tribunalSecurity.test.ts src/__tests__/susReports.test.ts src/__tests__/firelightBehavior.test.ts",
    "test:firestore-rules": "firebase emulators:exec --only firestore \"tsx --test src/__tests__/firelightRules.integration.test.ts\"",
    "test:skins": "tsx --test src/__tests__/skinArchitecture.test.ts",
    "test:skin-rules": "firebase emulators:exec --only firestore \"tsx --test src/__tests__/skinRules.integration.test.ts\""
  },
  "dependencies": {
    "@google/genai": "^2.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "exif-js": "^2.3.0",
    "express": "^5.2.1",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.10.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "motion": "^12.38.0",
    "node-cron": "^4.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.15.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@firebase/eslint-plugin-security-rules": "^0.0.2",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/exif-js": "^2.3.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.8.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.5.0",
    "firebase-tools": "^15.18.0",
    "jimp": "^1.6.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.13"
  }
}
